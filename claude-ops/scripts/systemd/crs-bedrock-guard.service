[Unit]
Description=Detect CRS Bedrock fallback traffic
After=crs-compose.service
Wants=crs-compose.service

[Service]
Type=oneshot
ExecStart=/usr/bin/node %h/.claude/scripts/account-rotation/crs-bedrock-guard.mjs
StandardOutput=append:%h/.claude/logs/crs-bedrock-guard.systemd.log
StandardError=append:%h/.claude/logs/crs-bedrock-guard.systemd.log
