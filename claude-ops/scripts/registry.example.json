{
  "version": "1.0",
  "owner": "Your Name",
  "projects": [
    {
      "alias": "my-app",
      "paths": ["~/Projects/my-app"],
      "repos": ["your-org/my-app"],
      "org": "your-org",
      "type": "monorepo",
      "infra": {
        "platform": "vercel"
      },
      "revenue": { "model": "saas", "stage": "pre-launch" },
      "gsd": true,
      "priority": 1
    },
    {
      "alias": "my-store",
      "source": "shopify",
      "type": "external",
      "shopify": {
        "store_url": "yourstore.myshopify.com",
        "credential_key": "SHOPIFY_TOKEN"
      },
      "revenue": { "model": "ecommerce", "stage": "growth" },
      "priority": 3
    },
    {
      "alias": "eng-team",
      "source": "linear",
      "type": "external",
      "linear": { "team_key": "ENG" },
      "priority": 5
    }
  ]
}
