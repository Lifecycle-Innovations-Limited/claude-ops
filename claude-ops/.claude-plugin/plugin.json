  "license": "MIT",
  "keywords": ["business", "operations", "communications", "yolo"],
  "userConfig": {
    "telegram_bot_token": {
      "title": "Telegram Bot Token",
      "description": "Telegram Bot API token from @BotFather (optional)",
      "type": "string",
      "sensitive": true
    },
    "telegram_owner_id": {
      "title": "Telegram Owner ID",
      "description": "Your Telegram user ID (optional)",
      "type": "string",
      "sensitive": false
    },
    "sentry_org": {
      "title": "Sentry Organization",
      "description": "Sentry organization slug e.g. 'healify' (optional)",
      "type": "string",
      "sensitive": false
    },
    "linear_team": {
      "title": "Linear Team Key",
      "description": "Default Linear team key e.g. 'HEA' (optional)",
      "type": "string",
      "sensitive": false
    },
    "aws_region": {
      "title": "AWS Region",
      "description": "Default AWS region for infra checks e.g. 'us-east-1' (optional)",
      "type": "string",
      "sensitive": false
    }
  }
}
