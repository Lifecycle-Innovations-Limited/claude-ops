# Root-level gitignore for the marketplace wrapper repo
.claude/
.planning/
.DS_Store
node_modules/
*.log
.worktrees/
.gstack/

# Operator PII denylist (out-of-repo, loaded by test-no-secrets.sh / pre-commit)
.pii-denylist

# Local, owner-specific prefs/overrides — never commit (see docs/LOCAL-PREFS.md)
ops.local.json
*.local.json
.ops-prefs.json
